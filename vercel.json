{
  "cleanUrls": true,
  "installCommand": "cd frontend && npm install",
  "buildCommand": "cd frontend && npx next build",
  "outputDirectory": "frontend/out",
  "rewrites": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "api.burnlens.app" }],
      "destination": "https://burnlens-proxy-production.up.railway.app/:path*"
    },
    { "source": "/favicon.ico", "destination": "/icon.svg" },
    { "source": "/apple-touch-icon.png", "destination": "/icon.svg" },
    { "source": "/apple-touch-icon-precomposed.png", "destination": "/icon.svg" }
  ],
  "redirects": [
    { "source": "/signup", "destination": "/setup?intent=register", "permanent": false },
    { "source": "/signup.html", "destination": "/setup?intent=register", "permanent": false },
    { "source": "/login", "destination": "/setup", "permanent": false },
    { "source": "/login.html", "destination": "/setup", "permanent": false },
    { "source": "/register", "destination": "/setup?intent=register", "permanent": false },
    { "source": "/pricing", "destination": "/#pricing", "permanent": false },
    { "source": "/dashboard.html", "destination": "/dashboard", "permanent": false }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.paddle.com https://*.paddle.com https://*.profitwell.com; style-src 'self' 'unsafe-inline' https://cdn.paddle.com; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://api.burnlens.app https://*.paddle.com https://*.profitwell.com https://burnlens-proxy-production.up.railway.app; frame-src https://*.paddle.com; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
        }
      ]
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "api.burnlens.app" }],
      "headers": [
        { "key": "Cache-Control", "value": "private, no-store" }
      ]
    },
    {
      "source": "/(opengraph-image|twitter-image)",
      "headers": [
        { "key": "Content-Type", "value": "image/png" },
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    }
  ]
}
