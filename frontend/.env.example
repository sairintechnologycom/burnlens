# TokenLens Frontend Environment Variables

# Backend API URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Lemon Squeezy checkout URLs (from your store dashboard)
NEXT_PUBLIC_CHECKOUT_PERSONAL=https://tokenlens.lemonsqueezy.com/checkout/buy/YOUR_PERSONAL_VARIANT_ID
NEXT_PUBLIC_CHECKOUT_TEAM=https://tokenlens.lemonsqueezy.com/checkout/buy/YOUR_TEAM_VARIANT_ID
