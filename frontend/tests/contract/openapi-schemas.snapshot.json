  "BillingSummary": {
    "description": "Read model for GET /billing/summary.\n\nReflects the workspaces-row cache written by the Paddle webhook (Phase 7).\nNo Paddle API round-trip on read. `price_cents` and `currency` are null for\nfree-tier workspaces (D-07). Date fields are null when Paddle has not\npopulated them (free plan, or new sub before first Paddle payload).\n`status` values expected from Paddle: 'active' | 'trialing' | 'past_due'\n| 'canceled' | 'paused'. Stored as plain str so Paddle can add new states\nwithout breaking the read path.",
    "properties": {
      "api_keys": {
        "anyOf": [
          {
            "$ref": "#/components/schemas/ApiKeysSummary"
          },
          {
            "type": "null"
          }
        ]
      },
      "available_plans": {
        "items": {
          "$ref": "#/components/schemas/AvailablePlan"
        },
        "title": "Available Plans",
        "type": "array"
      },
      "cancel_at_period_end": {
        "default": false,
        "title": "Cancel At Period End",
        "type": "boolean"
      },
      "currency": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "title": "Currency"
      },
      "current_period_ends_at": {
        "anyOf": [
          {
            "format": "date-time",
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "title": "Current Period Ends At"
      },
      "plan": {
        "title": "Plan",
        "type": "string"
      },
      "price_cents": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "title": "Price Cents"
      },
      "scheduled_change_at": {
        "anyOf": [
          {
            "format": "date-time",
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "title": "Scheduled Change At"
      },
      "scheduled_plan": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "title": "Scheduled Plan"
      },
      "status": {
        "title": "Status",
        "type": "string"
      },
      "trial_ends_at": {
        "anyOf": [
          {
            "format": "date-time",
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "title": "Trial Ends At"
      },
      "usage": {
        "anyOf": [
          {
            "$ref": "#/components/schemas/UsageCurrentCycle"
          },
          {
            "type": "null"
          }
        ]
      }
