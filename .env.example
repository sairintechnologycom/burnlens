# BurnLens environment variables
# Copy to .env and fill in your values

# Railway / deployment
PORT=8420
BURNLENS_DB_PATH=/data/burnlens.db
BURNLENS_CONFIG_PATH=/data/burnlens.yaml

# Provider API keys (at least one required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Optional: admin keys for billing detection
OPENAI_ADMIN_KEY=
ANTHROPIC_ADMIN_KEY=

# Dashboard auth (REQUIRED for public deployments — without these, /ui and /api are open)
DASHBOARD_USER=
DASHBOARD_PASS=

# Optional: CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=

# Optional: log level (debug, info, warning, error)
LOG_LEVEL=info
