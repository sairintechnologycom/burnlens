# BurnLens Cloud Backend Configuration
# Copy to .env and fill in actual values for local development

# PostgreSQL connection (Vercel Postgres provides this in production)
DATABASE_URL=postgresql+asyncpg://localhost/burnlens_cloud

# JWT secret for token signing (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=dev-secret-change-in-production

# Stripe API keys (get from https://dashboard.stripe.com/apikeys)
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_test_...

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
